
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGER
  STORE_KEEPER
}

enum ProductStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STORE_KEEPER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String
  category    String
  quantity    Float
  unit        String
  price       Float
  supplier    String
  status      ProductStatus @default(IN_STOCK)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
